{
  "name": "smart-health-system-backend",
  "version": "1.0.0",
  "description": "Backend API for Smart Health System - Medical AI Assistant with Gemini integration",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "test": "jest --verbose --coverage",
    "test:watch": "jest --watch",
    "test:api": "node test-gemini-api.js",
    "check:gemini": "node check-gemini.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "clean": "rm -rf logs uploads node_modules",
    "install-deps": "npm install",
    "setup": "npm run install-deps && npm run db:seed",
    "db:seed": "node scripts/seed.js",
    "db:backup": "node scripts/backup.js",
    "db:cleanup": "node scripts/cleanup.js",
    "docs:generate": "node scripts/generate-docs.js",
    "docker:build": "docker build -t smart-health-system .",
    "docker:run": "docker run -p 4000:4000 smart-health-system"
  },
  "keywords": [
    "healthcare",
    "ai",
    "medical",
    "gemini",
    "api",
    "nodejs",
    "express",
    "postgresql",
    "typeorm"
  ],
  "author": {
    "name": "MADOUI MOHAMAD SADAK",
    "email": "mohamad.sadak@example.com",
    "url": "https://github.com/mohamadsadak2005-creator"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohamadsadak2005-creator/Smart-Health-System.git"
  },
  "bugs": {
    "url": "https://github.com/mohamadsadak2005-creator/Smart-Health-System/issues"
  },
  "homepage": "https://github.com/mohamadsadak2005-creator/Smart-Health-System#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "@types/pg": "^8.15.6",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.5.0",
    "chart.js": "^4.4.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mongoose": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4",
    "pg": "^8.16.3",
    "redis": "^4.6.8",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.28",
    "validator": "^13.9.0"
  },
  "devDependencies": {
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "utils/**/*.js",
      "middleware/**/*.js",
      "models/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "trailingComma": "es5"
  }
}
